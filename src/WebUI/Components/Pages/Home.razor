@page "/"

<PageTitle>Home</PageTitle>

<div class="main-container">
    <div class="bg-secondary text-center py-5 shadow" style="border-radius: 10px;">
        <h1 class="display-4 text-white"><i class="bi bi-lightning-charge-fill me-2 text-warning"></i>EventHub Explorer</h1>
        <p class="lead text-white">Effortlessly send, receive, and explore data from your Azure EventHubs streams and StorageQueues</p>
    </div>
    <div class="container my-5">
        
        <section>
            <h2 class="text-center mb-4">How to Use It</h2>
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="card bg-primary text-white text-center h-100">
                        <div class="card-body d-flex flex-column">
                            <div>
                                <i class="bi bi-plugin fs-1 mb-3"></i>
                                <h5 class="card-title" style="min-height: 3.5rem">1. Connect</h5>
                            </div>
                            <div class="flex-grow-1 d-flex flex-column justify-content-center">
                                <p class="card-text">
                                    Create connection configuration to Message Bus service.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-primary text-white text-center h-100">
                        <div class="card-body d-flex flex-column">
                            <div>
                                <i class="bi bi-send-fill fs-1 mb-3"></i>
                                <h5 class="card-title" style="min-height: 3.5rem">2. Send messages to Message Bus service.</h5>
                            </div>
                            <div class="flex-grow-1 d-flex flex-column justify-content-center">
                                <p class="card-text">
                                    Send one, multiple messages, or multiple with delay between each message.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-primary text-white text-center h-100">
                        <div class="card-body d-flex flex-column">
                           <div>
                                <i class="bi bi-broadcast fs-1 mb-3"></i>
                                <h5 class="card-title" style="min-height: 3.5rem">3. Start Listening</h5>
                            </div>
                            <div class="flex-grow-1 d-flex flex-column justify-content-center">
                                <p class="card-text">Click "Start Receive" to stream data from Message Bus service in real time.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-primary text-white text-center h-100">
                        <div class="card-body d-flex flex-column">
                            <div>
                                <i class="bi bi-file-earmark-text-fill fs-1 mb-3"></i>
                                <h5 class="card-title" style="min-height: 3.5rem">4. Analyze Events</h5>
                            </div>
                            <div class="flex-grow-1 d-flex flex-column justify-content-center">
                                <p class="card-text">Inspect received messages in same place.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>    
</div>